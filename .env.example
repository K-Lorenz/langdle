# Database
DATABASE_URL="postgres://langdle:langdle@localhost:5432/langdle"

# App
PUBLIC_BASE_URL="https://langdle.de"

# Optional: Autocomplete-Deckel (Standard 6500); der Ratepool ist ohnehin nur Snapshot + Extras.
# VOCABULARY_CLIENT_LIMIT=6500

# Optional: Pfad zur Puzzle-Meta-JSON (targetGerman, targetForeign, languageIso639_3, gridSize, …).
# Gitter-Lemmata: mit Embeddings bevorzugt aus Kaikki + DB-Vektoren, sonst ConceptNet (keine Lemma-Liste in der JSON).
# Standard: data/puzzle-spec.json  |  Seed: npm run db:seed (nach Kaikki-Import + optional db:embeddings).
# PUZZLE_SPEC_PATH=data/puzzle-spec.json

# Optional: Seed-Gitter — `embedding` erzwingen (scheitert ohne Embeddings), `conceptnet` ConceptNet erzwingen.
# PUZZLE_GRID_SOURCE=

# Optional: Embedding-Job in Docker — Modell/Batch (Compose-Service `embeddings`, siehe README).
# EMBEDDING_MODEL=paraphrase-multilingual-MiniLM-L12-v2
# EMBEDDING_BATCH=64
# EMBEDDING_SAVE_PROGRESS_INTERVAL=5000

# Empfohlen für Seed: lokaler ConceptNet (sonst öffentliche API, oft weniger Kanten).
# RCONCEPTNET_URL=http://127.0.0.1:3043

# Optional: Fortschrittsbalken beim Seed unterdrücken (Logs/CI).
# SEED_QUIET=1

# Optional: lokaler ConceptNet (Binary + SQLite), siehe README.
# Lokal (Host): http://127.0.0.1:3043  |  Docker Compose: http://conceptnet:3043
# RCONCEPTNET_URL="http://127.0.0.1:3043"
